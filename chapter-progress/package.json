{
  "name": "chapter-progress",
  "version": "1.0.0",
  "description": "Hierarchical chapter progress bar animation with Remotion",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render src/index.tsx ChapterProgress out/progress.mp4",
    "build:custom": "remotion render src/index.tsx ChapterProgress out/progress.mp4 --props=data.json"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.450",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.450"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
